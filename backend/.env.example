JWT_SECRET=generate-a-strong-random-value-at-least-32-chars
CORS_ORIGINS=http://localhost:3000

GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Groq API (primary). Use GROQ_API_KEYS for round-robin rotation across keys.
GROQ_API_KEY=your-groq-api-key-here
# GROQ_API_KEYS=key1,key2,key3
GROQ_MODEL=llama-3.3-70b-versatile
# Global fallback chain across providers/models.
# Format: provider:model,provider:model,...
# Default order:
# groq:llama-3.3-70b-versatile
# groq:meta-llama/llama-4-scout-17b-16e-instruct
# groq:openai/gpt-oss-120b
# groq:qwen/qwen3-32b
# groq:llama-3.1-8b-instant
# gemini:gemini-2.5-flash
# ollama:gemma4:e4b-it-q4_K_M
# LLM_FALLBACK_CHAIN=groq:llama-3.3-70b-versatile,groq:meta-llama/llama-4-scout-17b-16e-instruct,groq:openai/gpt-oss-120b,groq:qwen/qwen3-32b,groq:llama-3.1-8b-instant,gemini:gemini-2.5-flash,ollama:gemma4:e4b-it-q4_K_M

# Optional local LLM via Ollama
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b

UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE_MB=50
CHUNK_SIZE=2000
CHUNK_OVERLAP=200

# Per-user safety limits
MAX_GENERATIONS_PER_HOUR=20
